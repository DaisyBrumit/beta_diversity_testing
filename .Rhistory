# filterIQR adapted by yours truly from python walkthrough in G4G: Dec. 2021
filterIQR <- function(matrix, col) {
v <- matrix[[col]]
Q1 <- quantile(v, probs = 0.25)
Q3 <- quantile(v, probs = 0.75)
IQR <- IQR(v)
lower = Q1 - 1.5 * IQR
upper = Q3 + 1.5 * IQR
outlier_free_list <<- filter(matrix[i], matrix[i] > lower & matrix[i] < upper )
filtered_data <<- filter(matrix, rownames(matrix) %in% rownames(outlier_free_list))
}
for (i in colnames(matrix)) {
if i == colnames(matrix[1]) {
for (i in colnames(matrix)) {
if (i == colnames(matrix[1])) {
filterIQR(matrix, i)
}
else {
filterIQR(filtered_data, i)
}
}
