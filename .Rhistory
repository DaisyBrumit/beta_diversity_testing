library(tidyverse)
# Line graph with
# x: metric of interest (accuracy)
# y: derived trend to observe (# of principle components)
# group: classes of interest (beta diversity method)
# scale: a vector containing min and max Y-axis values
plt <- ggplot(df, aes(x=x, y=y, color=group, group=group)) +
geom_smooth(na.rm=TRUE, se=FALSE) +
scale_y_continuous(limits=scale) +
labs(title=title, subtitle=subtitle) +
theme(axis.text.x = element_text(angle=45, hjust=0.5, vjust=0.5),
plot.title = element_text(size=10, face = 'bold'))
preplot.filter <- function(df) {
df.nas <- df %>% mutate(across(everything(), ~ifelse(.x == 999, NA, .x))) # turn all 999 into na
df.filtered <- df.nas %>% dplyr::select_if(~ !any(is.na(.))) # remove whole column if all labels are na
removed.cols <- df.nas %>% dplyr::select_if(~ any(is.na(.))) # get list of na cols
print(paste(ncol(removed.cols), 'features removed \n', colnames(removed.cols))) # print column names
return(df.filtered)
}
runif(10)
my_tibble <- tibble(
Numeric_Column = runif(10),                       # 1 column of random numeric values
Numeric_Column_with_NAs = c(runif(4), rep(NA, 6)), # 1 column of random numeric values with NA's
Categorical_Column = sample(letters[1:5], 10, replace = TRUE),  # 1 categorical column
Categorical_Column_with_NAs = c(sample(letters[1:5], 4, replace = TRUE), rep(NA, 6)),  # 1 categorical column with NA's
NA_Column = rep(NA, 10)                          # 1 categorical column populated entirely with NA's
)
View(my_tibble)
df.nas <- df %>% mutate(across(everything(), ~ifelse(.x == 999, NA, .x))) # turn all 999 into na
